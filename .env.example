# Copy this to .env and fill in your values
# cp .env.example .env

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Postgres (used locally; docker-compose overrides DATABASE_URL automatically)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hotel_db

# ── App settings (optional — defaults shown) ─────────────────────────────────
CONFIDENCE_THRESHOLD=0.6
CANCEL_CONFIDENCE_THRESHOLD=0.75
OTA_URL=http://localhost:9000
OTA_MAX_RETRIES=5
